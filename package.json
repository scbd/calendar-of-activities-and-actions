{
  "name": "calendar-of-activities-and-actions",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --open",
    "generate": "nuxt generate",
    "preview": "nuxt preview --open",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "typecheck:watch": "nuxt typecheck --watch",
    "prebuild": "nuxt typecheck",
    "test": "vitest --run",
    "test:unit": "vitest --run --project unit",
    "test:nuxt": "vitest run test/nuxt/**/*.test.ts",
    "test:e2e": "VITEST_E2E=1 vitest --run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/eslint": "1.9.0",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/image": "1.11.0",
    "@nuxt/test-utils": "3.19.2",
    "consola": "^3.2.3",
    "eslint": "^9.0.0",
    "nuxt": "^4.1.1",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.7.9",
    "@vitest/coverage-v8": "3.2.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^18.0.1",
    "playwright": "^1.55.0",
    "playwright-core": "^1.55.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.6"
  }
}
