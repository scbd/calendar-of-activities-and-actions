{
  "name": "calendar-of-activities-and-actions",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt cleanup && nuxt dev --open",
    "generate": "nuxt generate",
    "preview": "nuxt preview --open",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "typecheck:watch": "nuxt typecheck --watch",
    "test": "vitest --run",
    "test:unit": "vitest --run --project unit",
    "test:nuxt": "vitest run test/nuxt/**/*.test.ts",
    "test:e2e": "VITEST_E2E=1 vitest --run --project e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean-reinstall": "rm -rf node_modules package-lock.json .nuxt && npm install"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.1.0",
    "@fortawesome/free-solid-svg-icons": "7.1.0",
    "@fortawesome/vue-fontawesome": "3.1.2",
    "@nuxt/eslint": "1.9.0",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/image": "1.11.0",
    "@nuxt/test-utils": "3.19.2",
    "@nuxtjs/i18n": "10.1.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "consola": "3.4.2",
    "eslint": "9.35.0",
    "luxon": "3.5.0",
    "nuxt": "4.1.2",
    "v-click-outside": "3.2.0",
    "vue": "3.5.21",
    "vue-multiselect": "3.3.1",
    "vue-router": "4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/bootstrap": "5.2.10",
    "@types/node": "22.18.6",
    "@vitest/coverage-v8": "3.2.4",
    "@vue/test-utils": "2.4.6",
    "happy-dom": "18.0.1",
    "playwright": "1.55.0",
    "playwright-core": "1.55.0",
    "sass": "1.77.8",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "vue-tsc": "2.2.12"
  }
}
