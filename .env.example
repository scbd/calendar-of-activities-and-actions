# Environment variable template for Jira automation scripts and MCP prompts
# Copy to .env and fill in secure values. Do NOT commit the populated .env file.

# Base URL of your Jira Cloud instance (no trailing slash)
JIRA_BASE_URL=https://scbd.atlassian.net

# Atlassian Cloud ID (UUID). Needed for certain platform APIs outside core REST issue endpoints.
ATLASSIAN_CLOUD_ID=00000000-0000-0000-0000-000000000000

# Authorization header value (typically: Bearer <APIToken or PAT>)
# Example: "Bearer abc123..."
JIRA_AUTH_HEADER=Bearer REPLACE_ME

# Optional: Custom field IDs if you prefer pinning (otherwise discover dynamically)
JIRA_EPIC_LINK_FIELD_ID=customfield_10014
JIRA_STORY_POINTS_FIELD_ID=customfield_10026
JIRA_PLANED_START_FIELD_ID=customfield_10046
JIRA_PLANED_END_FIELD_ID=customfield_10047

# User account ID (Atlassian accountId) for assignment if automation needs explicit value
# JIRA_ASSIGNEE_ACCOUNT_ID=replace-account-id

